# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/edvance
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ─── OTP ─────────────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-django-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ACCOUNT_ID=

# ─── SQS Queues ──────────────────────────────────────────────────────────────
SQS_SCORING_QUEUE_URL=
SQS_NOTIFICATION_QUEUE_URL=
SQS_RANKS_QUEUE_URL=

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=edvance-assets
R2_PUBLIC_URL=https://assets.edvance.in

# ─── WhatsApp (Meta Business API) ────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ─── SMS ─────────────────────────────────────────────────────────────────────
MSG91_API_KEY=

# ─── Email (AWS SES) ─────────────────────────────────────────────────────────
SES_FROM_EMAIL=noreply@edvance.in
SES_REGION=ap-south-1

# ─── Payment (Razorpay) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Monitoring ──────────────────────────────────────────────────────────────
SENTRY_DSN=
CLOUDWATCH_LOG_GROUP=/edvance/production

# ─── FCM (Push Notifications) ────────────────────────────────────────────────
FCM_SERVER_KEY=
