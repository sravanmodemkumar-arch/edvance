# =============================================================================
# EDVANCE — PRODUCTION ENVIRONMENT
# WARNING: Never commit real values here. Use AWS Secrets Manager for all
#          secrets in production. Replace every CHANGE_ME before deploying.
# =============================================================================

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
LOG_LEVEL=WARNING
PLATFORM_DOMAIN=edvance.in

# ─── Database (RDS PostgreSQL 16) ────────────────────────────────────────────
DATABASE_URL=postgresql://edvance_prod:CHANGE_ME@edvance-prod-db.ap-south-1.rds.amazonaws.com:5432/edvance
DATABASE_HOST=edvance-prod-db.ap-south-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_NAME=edvance
DATABASE_USER=edvance_prod
DATABASE_PASSWORD=CHANGE_ME
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_READ_REPLICA_URL=postgresql://edvance_prod:CHANGE_ME@edvance-prod-replica.ap-south-1.rds.amazonaws.com:5432/edvance

# ─── JWT / Auth ──────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_ME_USE_AWS_SECRETS_MANAGER
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ─── Django ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE_ME_USE_AWS_SECRETS_MANAGER
ALLOWED_HOSTS=edvance.in,*.edvance.in,*.schools.edvance.in,*.colleges.edvance.in,*.coaching.edvance.in,ssc.edvance.in,rrb.edvance.in,banking.edvance.in,upsc.edvance.in
CORS_ORIGINS=https://edvance.in,https://*.edvance.in

# ─── Super Admin ─────────────────────────────────────────────────────────────
SUPERADMIN_NAME=Platform Admin
SUPERADMIN_EMAIL=CHANGE_ME@edvance.in
SUPERADMIN_MOBILE=CHANGE_ME
SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SUPERADMIN_ROLE=platform_admin

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_ACCOUNT_ID=CHANGE_ME
AWS_KMS_KEY_ID=CHANGE_ME

# ─── SQS Queues ──────────────────────────────────────────────────────────────
SQS_SCORING_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/ACCOUNT/edvance-prod-scoring
SQS_NOTIFICATION_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/ACCOUNT/edvance-prod-notification
SQS_RANKS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/ACCOUNT/edvance-prod-ranks
SQS_EMAIL_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/ACCOUNT/edvance-prod-email
SQS_BILLING_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/ACCOUNT/edvance-prod-billing

# ─── EventBridge ─────────────────────────────────────────────────────────────
EVENTBRIDGE_BUS_NAME=edvance-prod-events

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_NAME=edvance-prod-assets
R2_EXAM_BUCKET=edvance-prod-exams
R2_PUBLIC_URL=https://assets.edvance.in
CDN_EXAM_URL=https://exams.edvance.in
CLOUDFLARE_API_TOKEN=CHANGE_ME
CLOUDFLARE_ZONE_ID=CHANGE_ME

# ─── Exam Engine ─────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
EXAM_ENCRYPTION_SALT=CHANGE_ME_USE_AWS_SECRETS_MANAGER
EXAM_SESSION_DURATION_MINUTES=180
EXAM_MAX_CONCURRENT_SESSIONS=74000

# ─── WhatsApp (Meta Business API via BSP) ────────────────────────────────────
WHATSAPP_BSP=gupshup
WHATSAPP_TOKEN=CHANGE_ME
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_WABA_ID=CHANGE_ME
WHATSAPP_VERIFY_TOKEN=CHANGE_ME
WHATSAPP_WEBHOOK_URL=https://api.edvance.in/notifications/whatsapp/webhook
WHATSAPP_DAILY_LIMIT_TIER=high

# ─── SMS (MSG91) ─────────────────────────────────────────────────────────────
MSG91_API_KEY=CHANGE_ME
MSG91_SENDER_ID=EDVNCE
MSG91_TEMPLATE_ID_OTP=CHANGE_ME
MSG91_TEMPLATE_ID_ALERT=CHANGE_ME

# ─── Email (AWS SES) ─────────────────────────────────────────────────────────
SES_FROM_EMAIL=noreply@edvance.in
SES_FROM_NAME=Edvance
SES_REPLY_TO=support@edvance.in
SES_REGION=ap-south-1
SES_CONFIGURATION_SET=edvance-prod

# ─── Payment (Razorpay — LIVE Keys) ──────────────────────────────────────────
RAZORPAY_KEY_ID=CHANGE_ME_LIVE_KEY
RAZORPAY_KEY_SECRET=CHANGE_ME_LIVE_SECRET
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME
RAZORPAY_ACCOUNT_NUMBER=CHANGE_ME

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://edvance.in/auth/google/callback

# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=CHANGE_ME
ANTHROPIC_MODEL=claude-opus-4-6

# ─── FCM (Push Notifications) ────────────────────────────────────────────────
FCM_SERVER_KEY=CHANGE_ME
FCM_PROJECT_ID=CHANGE_ME

# ─── Monitoring ──────────────────────────────────────────────────────────────
SENTRY_DSN=CHANGE_ME
SENTRY_TRACES_SAMPLE_RATE=0.1
CLOUDWATCH_LOG_GROUP=/edvance/production
CLOUDWATCH_LOG_STREAM=application

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_OTP_PER_HOUR=3
RATE_LIMIT_API_PER_MINUTE=60
RATE_LIMIT_EXAM_SUBMIT_PER_DAY=5

# ─── Multi-Tenancy ───────────────────────────────────────────────────────────
DEFAULT_TENANT_SCHEMA=public
TENANT_HEADER=X-Tenant-ID
SUBDOMAIN_BASE=edvance.in

# ─── Security ────────────────────────────────────────────────────────────────
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
HSTS_SECONDS=31536000
CERT_IN_CONTACT_EMAIL=security@edvance.in
