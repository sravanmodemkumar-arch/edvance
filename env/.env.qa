# ─── Exam Engine ─────────────────────────────────────────────────────────────
EXAM_ENCRYPTION_SALT=5dee3d20fff38827ef6fc410fcd95cf9
EXAM_SESSION_DURATION_MINUTES=180
EXAM_MAX_CONCURRENT_SESSIONS=1000

# ─── WhatsApp (BSP) ──────────────────────────────────────────────────────────
