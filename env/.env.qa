# ─── SMS (MSG91) ─────────────────────────────────────────────────────────────
MSG91_API_KEY=CHANGE_ME
MSG91_SENDER_ID=EDVNCE
MSG91_TEMPLATE_ID_OTP=CHANGE_ME

# ─── Email (AWS SES) ─────────────────────────────────────────────────────────
SES_FROM_EMAIL=qa@edvance.in
SES_FROM_NAME=Edvance QA
SES_REGION=ap-south-1
SES_CONFIGURATION_SET=edvance-qa

# ─── Payment (Razorpay — Test Keys) ──────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://qa.edvance.in/auth/google/callback

# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=CHANGE_ME
