FCM_PROJECT_ID=CHANGE_ME

# ─── Monitoring ──────────────────────────────────────────────────────────────
SENTRY_DSN=CHANGE_ME
CLOUDWATCH_LOG_GROUP=/edvance/qa
CLOUDWATCH_LOG_STREAM=application

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_OTP_PER_HOUR=5
RATE_LIMIT_API_PER_MINUTE=60
RATE_LIMIT_EXAM_SUBMIT_PER_DAY=10

# ─── Multi-Tenancy ───────────────────────────────────────────────────────────
DEFAULT_TENANT_SCHEMA=public
TENANT_HEADER=X-Tenant-ID
SUBDOMAIN_BASE=qa.edvance.in
